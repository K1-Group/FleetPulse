# FleetPulse Environment Configuration

# AI Provider Configuration (choose one)
# Option 1: Anthropic API (pay-per-use)
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option 2: OpenRouter API (connects Claude Max/Pro subscriptions)
OPENROUTER_API_KEY=your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_SITE_URL=https://k1-fleetpulse.azurewebsites.net
OPENROUTER_APP_NAME=FleetPulse

# GeoTab Configuration
GEOTAB_SERVER=my.geotab.com
GEOTAB_USERNAME=your-username
GEOTAB_PASSWORD=your-password
GEOTAB_DATABASE=your-database
# Optional: pin to the Access URL shown in MyGeotab Data Connector.
# If unset, FleetPulse starts at https://data-connector.geotab.com/odata/v4/svc/
# and follows the redirect to the database's current federation server.
# Current K1logistics discovery result:
GEOTAB_ODATA_SERVER=https://odata-connector-2.geotab.com/odata/v4/svc/

# FleetPulse live data scope
# Count active Geotab power units, not inactive history or trailers.
FLEETPULSE_DEVICE_GROUP_IDS=GroupVehicleId
FLEETPULSE_EXCLUDED_DEVICE_GROUP_IDS=GroupTrailerId
FLEETPULSE_REQUIRE_ACTIVE_LIFECYCLE=true
FLEETPULSE_STATUS_STALE_HOURS=24
FLEETPULSE_SAFETY_DEMO_MODE=false
FLEETPULSE_MONITOR_ENABLED=false
FLEETPULSE_GEOTAB_TIMEOUT_SECONDS=10
FLEETPULSE_GEOTAB_MAX_WORKERS=4
FLEETPULSE_CACHE_TTL_SECONDS=30
FLEETPULSE_CACHE_FALLBACK_SECONDS=300
FLEETPULSE_CACHE_REFRESH_WAIT_SECONDS=30
FLEETPULSE_HUBS_CONFIG_PATH=backend/configs/fleet_hubs.json
# Optional JSON override for hub metadata/radii. Use app settings or Key Vault,
# not code changes, when production hub boundaries need operational adjustment.
# FLEETPULSE_HUBS_JSON={"default_radius_miles":25,"hubs":[{"name":"Austin Hub","address":"Austin, TX","latitude":30.2672,"longitude":-97.7431,"radius_miles":25}]}

# Optional Microsoft Entra login. Azure App Service Authentication / Easy Auth
# is the identity authority. Keep AUTH_REQUIRED=false for public dashboard mode;
# set LOGIN_ENABLED=true to show the sign-in control without forcing SSO.
FLEETPULSE_ENTRA_LOGIN_ENABLED=true
FLEETPULSE_ENTRA_AUTH_REQUIRED=false
FLEETPULSE_ENTRA_SEAT_ACCESS_ENFORCED=false
FLEETPULSE_ENTRA_AUDIT_DECISIONS=true
FLEETPULSE_ENTRA_PUBLIC_TABS=dashboard,control-tower,maintenance,stability
FLEETPULSE_ENTRA_SEAT_GROUPS_JSON={"executive_command":{"groupId":"<EXECUTIVE_COMMAND_SEAT_GROUP_OBJECT_ID>"},"revenue_manager":{"groupId":"<REVENUE_MANAGER_SEAT_GROUP_OBJECT_ID>"},"operations_manager":{"groupId":"<OPERATIONS_MANAGER_SEAT_GROUP_OBJECT_ID>"},"finance_controller":{"groupId":"<FINANCE_CONTROLLER_SEAT_GROUP_OBJECT_ID>"},"fleet_compliance_manager":{"groupId":"<FLEET_COMPLIANCE_MANAGER_SEAT_GROUP_OBJECT_ID>"},"people_systems_manager":{"groupId":"<PEOPLE_SYSTEMS_MANAGER_SEAT_GROUP_OBJECT_ID>"}}

# Application Configuration
DEBUG=False
LOG_LEVEL=INFO

# Zapier Integration (optional)
# Keep disabled until a Zapier Catch Hook URL is configured.
FLEETPULSE_ZAPIER_ENABLED=false
FLEETPULSE_ZAPIER_WEBHOOK_URL=
FLEETPULSE_ZAPIER_API_KEY=
FLEETPULSE_ZAPIER_SHARED_SECRET=
FLEETPULSE_ZAPIER_TIMEOUT_SECONDS=15

# HR recruiting worklist monitor. The default deployed-safe source is the
# approved HR_Lead_KPI_Recheck_By_Phone workbook. FleetPulse remains read-only
# analytics and never writes to Tenstreet, Grasshopper, SharePoint, or Xcelerator.
ZAPIER_JOB_APPLICANTS_TABLE_ID=01KR00WV4YHCB6BMYDE1EG7HEM
HR_WORKLIST_SLA_HOURS=24,48,72
HR_RECRUITING_SOURCE=hr_kpi_workbook
HR_RECRUITING_WORKBOOK_PATH=/home/data/HR_Lead_KPI_Recheck_By_Phone.xlsx
HR_RECRUITING_SNAPSHOT_URL=
HR_RECRUITING_STATE_PATH=/home/data/fleetpulse_hr_recruiting.json
SHAREPOINT_HR_REPORTING_LOG_URL=

# Original Control Tower dashboard projections (optional, read-only)
FLEETPULSE_TRAILER_GROUP_IDS=GroupTrailerId
FLEETPULSE_TRAILER_STATUS_STALE_HOURS=48
FLEETPULSE_TRAILER_MATCH_RADIUS_METERS=150
FLEETPULSE_TRAILER_DRIVER_LOOKBACK_HOURS=12

# K1 Operations Hub migration. FleetPulse replaces legacy K1 Command Center
# front-end surfaces over time while backend services remain separate.
FLEETPULSE_ENABLE_AP_STATUS=false
FLEETPULSE_AP_LIFECYCLE_API_URL=
FLEETPULSE_FINANCEOPS_HEALTH_API_URL=
FLEETPULSE_POWERBI_WORKSPACE_ID=
FLEETPULSE_ENABLE_WRITEBACK=false

# K1 seat-based operating system portal contract.
# API-key auth is required. Call read-only endpoints with
# X-FleetPulse-Operating-System-Key or X-API-Key.
# For local Vite dev, set the same key in the Vite server environment so the
# dev proxy can inject it server-side; do not ship secret API keys in frontend code.
FLEETPULSE_OPERATING_SYSTEM_REQUIRE_API_KEY=true
FLEETPULSE_OPERATING_SYSTEM_API_KEY=
OPERATING_SYSTEM_API_KEY=
XCELERATOR_API_BASE_URL=
QBO_COMPANY_ID=
TIMEDOCTOR_API_BASE_URL=
SHAREPOINT_SITE_ID=

# Dashboard validation proof ledger. This is a local read-only audit of probe
# outcomes used for validation badges; it never writes source-of-truth systems.
FLEETPULSE_DASHBOARD_VALIDATION_LIVE_PROBE=false
FLEETPULSE_VALIDATION_AUDIT_PATH=/home/data/fleetpulse_validation_audit.json
FLEETPULSE_VALIDATION_AUDIT_RETAINED_RECORDS=5000
FLEETPULSE_SAFETY_SYNC_CADENCE_MINUTES=60
FLEETPULSE_ALERT_SYNC_CADENCE_MINUTES=60
FLEETPULSE_ALERT_ZERO_EVENT_AUDIT_ENABLED=false
FLEETPULSE_AGENTIC_MONITOR_AUDIT_REQUIRED_OK=3
FLEETPULSE_AGENTIC_MONITOR_AUDIT_WINDOW_MINUTES=15
FLEETPULSE_AGENTIC_MONITOR_AUDIT_WRITE_CADENCE_MINUTES=5
FLEETPULSE_FLEET_ANALYTICS_AUDIT_WRITE_CADENCE_MINUTES=60
FLEETPULSE_FLEET_ANALYTICS_EXPECTED_GRAIN=daily
FLEETPULSE_FLEET_ANALYTICS_MIN_PERIODS=7
FLEETPULSE_FLEET_ANALYTICS_WINDOW_DAYS=14
FLEETPULSE_FLEET_ANALYTICS_ALLOWED_GAP_DAYS=1

# Fleet report delivery. Email sending is routed through an approved
# Power Automate/Zapier webhook; when blank, FleetPulse falls back to a local
# email draft and still allows exports.
FLEETPULSE_REPORT_EMAIL_WEBHOOK_URL=
FLEETPULSE_REPORT_EMAIL_WEBHOOK_TOKEN=
FLEETPULSE_REPORT_SCHEDULE_PATH=/home/data/fleetpulse_report_schedule.json

