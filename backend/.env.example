# FleetPulse Environment Configuration

# AI Provider Configuration (choose one)
# Option 1: Anthropic API (pay-per-use)
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option 2: OpenRouter API (connects Claude Max/Pro subscriptions)
OPENROUTER_API_KEY=your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_SITE_URL=https://k1-fleetpulse.azurewebsites.net
OPENROUTER_APP_NAME=FleetPulse

# GeoTab Configuration
GEOTAB_SERVER=my.geotab.com
GEOTAB_USERNAME=your-username
GEOTAB_PASSWORD=your-password
GEOTAB_DATABASE=your-database
# Optional: pin to the Access URL shown in MyGeotab Data Connector.
# If unset, FleetPulse starts at https://data-connector.geotab.com/odata/v4/svc/
# and follows the redirect to the database's current federation server.
# Current K1logistics discovery result:
GEOTAB_ODATA_SERVER=https://odata-connector-2.geotab.com/odata/v4/svc/

# FleetPulse live data scope
# Count active Geotab power units, not inactive history or trailers.
FLEETPULSE_DEVICE_GROUP_IDS=GroupVehicleId
FLEETPULSE_EXCLUDED_DEVICE_GROUP_IDS=GroupTrailerId
FLEETPULSE_REQUIRE_ACTIVE_LIFECYCLE=true
FLEETPULSE_STATUS_STALE_HOURS=24
FLEETPULSE_SAFETY_DEMO_MODE=false
FLEETPULSE_MONITOR_ENABLED=false
FLEETPULSE_GEOTAB_TIMEOUT_SECONDS=10
FLEETPULSE_GEOTAB_MAX_WORKERS=4
FLEETPULSE_CACHE_TTL_SECONDS=30
FLEETPULSE_CACHE_FALLBACK_SECONDS=300

# Application Configuration
DEBUG=False
LOG_LEVEL=INFO

# Zapier Integration (optional)
# Keep disabled until a Zapier Catch Hook URL is configured.
FLEETPULSE_ZAPIER_ENABLED=false
FLEETPULSE_ZAPIER_WEBHOOK_URL=
FLEETPULSE_ZAPIER_API_KEY=
FLEETPULSE_ZAPIER_SHARED_SECRET=
FLEETPULSE_ZAPIER_TIMEOUT_SECONDS=15

# Original Control Tower dashboard projections (optional, read-only)
FLEETPULSE_TRAILER_GROUP_IDS=GroupTrailerId
FLEETPULSE_TRAILER_STATUS_STALE_HOURS=48
FLEETPULSE_TRAILER_MATCH_RADIUS_METERS=150
FLEETPULSE_TRAILER_DRIVER_LOOKBACK_HOURS=12

# K1 seat-based operating system portal contract.
# API-key auth is required. Call read-only endpoints with
# X-FleetPulse-Operating-System-Key or X-API-Key.
# For local Vite dev, set the same key in the Vite server environment so the
# dev proxy can inject it server-side; do not ship secret API keys in frontend code.
FLEETPULSE_OPERATING_SYSTEM_REQUIRE_API_KEY=true
FLEETPULSE_OPERATING_SYSTEM_API_KEY=
OPERATING_SYSTEM_API_KEY=
XCELERATOR_API_BASE_URL=
QBO_COMPANY_ID=
TIMEDOCTOR_API_BASE_URL=
SHAREPOINT_SITE_ID=

# XTRA Lease geofence ingestion. Use a least-privilege Microsoft Graph app
# limited to the mailbox below, and trigger POST /api/control-tower/trailers/xtra/ingest
# from Power Automate, Zapier, or another approved scheduler.
FLEETPULSE_XTRA_INGESTION_ENABLED=false
FLEETPULSE_XTRA_OUTLOOK_MAILBOX=
FLEETPULSE_XTRA_GEOFENCE_FOLDER=
FLEETPULSE_XTRA_INGESTION_API_KEY=
FLEETPULSE_GRAPH_TENANT_ID=
FLEETPULSE_GRAPH_CLIENT_ID=
FLEETPULSE_GRAPH_CLIENT_SECRET=
FLEETPULSE_XTRA_STATE_PATH=/home/data/fleetpulse_xtra_lease_ingestion_state.json
FLEETPULSE_XTRA_LOOKBACK_HOURS=48
FLEETPULSE_XTRA_MESSAGE_LIMIT=50
FLEETPULSE_XTRA_RETAINED_EVENT_LIMIT=500
FLEETPULSE_XTRA_TIMEOUT_SECONDS=15
FLEETPULSE_XTRA_RETRY_COUNT=2
FLEETPULSE_XTRA_RETRY_BACKOFF_SECONDS=1
FLEETPULSE_XTRA_SHAREPOINT_LOG_WEBHOOK_URL=
FLEETPULSE_XTRA_SHAREPOINT_LOG_API_KEY=
FLEETPULSE_TEAMS_ALERT_WEBHOOK_URL=
FLEETPULSE_TWILIO_ACCOUNT_SID=
FLEETPULSE_TWILIO_AUTH_TOKEN=
FLEETPULSE_TWILIO_FROM_NUMBER=
FLEETPULSE_TWILIO_ALERT_TO_NUMBER=
# AtoB manual fuel expense imports. FleetPulse stores downloaded report rows as
# read-only expense references for dashboard cost analytics.
FLEETPULSE_ATOB_FUEL_STATE_PATH=/home/data/fleetpulse_atob_fuel_expenses.json
FLEETPULSE_ATOB_FUEL_RETAINED_RECORDS=10000
FLEETPULSE_ATOB_SHAREPOINT_ENABLED=false
FLEETPULSE_ATOB_SHAREPOINT_SITE_URL=
FLEETPULSE_ATOB_SHAREPOINT_SITE_ID=
FLEETPULSE_ATOB_SHAREPOINT_DRIVE_ID=
FLEETPULSE_ATOB_SHAREPOINT_DRIVE_NAME=
FLEETPULSE_ATOB_SHAREPOINT_FOLDER_PATH=atob
# Optional: current Power BI semantic models point at uploaded SharePoint files.
# Use this for a file-backed connection while migrating to the shared folder.
FLEETPULSE_ATOB_SHAREPOINT_SOURCE_FILE_URLS=
FLEETPULSE_ATOB_SHAREPOINT_FILE_EXTENSIONS=.csv,.tsv,.txt,.json,.jsonl
FLEETPULSE_ATOB_SHAREPOINT_FILE_LIMIT=25
FLEETPULSE_ATOB_SHAREPOINT_INGESTION_API_KEY=
FLEETPULSE_ATOB_SHAREPOINT_TIMEOUT_SECONDS=20
FLEETPULSE_ATOB_SHAREPOINT_RETRY_COUNT=2
FLEETPULSE_ATOB_SHAREPOINT_RETRY_BACKOFF_SECONDS=1
FLEETPULSE_ATOB_POWERBI_WORKSPACE_ID=b801f80d-5303-4121-abd1-1163639ef58b
FLEETPULSE_ATOB_POWERBI_FOLDER_ID=5b6ccf55-37ff-436e-8e19-6d1152334928
FLEETPULSE_ATOB_POWERBI_UI_SUBFOLDER_ID=52730
FLEETPULSE_ATOB_POWERBI_REPORT_ID=42dd5456-e377-4fb2-bb77-d28ef3a4c25a
FLEETPULSE_ATOB_POWERBI_SEMANTIC_MODEL_ID=8212573f-83a8-418d-b144-73b65b503230
# Event/finance URLs are source pointers for future read-only adapters. Keep the
# financial flag false until those adapters are actually live.
FLEETPULSE_XCELERATOR_EVENT_FEED_URL=
FLEETPULSE_FINANCIAL_FEED_ENABLED=false
FLEETPULSE_QBO_FINANCIAL_FEED_URL=
FLEETPULSE_QBO_FINANCIAL_FEED_PATH=
FLEETPULSE_QBO_EXPENSE_FEED_URL=
FLEETPULSE_QBO_EXPENSE_FEED_PATH=
FLEETPULSE_QBO_EXPENSE_FEED_API_KEY=
FLEETPULSE_QBO_EXPENSE_FEED_API_KEY_HEADER=X-FleetPulse-QBO-Key
FLEETPULSE_QBO_INSURANCE_ACCOUNT_PATTERNS=insurance
FLEETPULSE_QBO_EXCLUDED_ACCOUNT_PATTERNS=accounts receivable,atob,carrier,cogs,contractor,cost of goods sold,diesel,driver pay,driver settlement,factoring,freight in,fuel,income,payroll,revenue,sales,wages
FLEETPULSE_POWER_AUTOMATE_ENABLED=false
FLEETPULSE_POWER_AUTOMATE_FLOW_URL=
FLEETPULSE_COPILOT_ENABLED=false
FLEETPULSE_COPILOT_AGENT_URL=
FLEETPULSE_REPOSITORY=

# Xcelerator lane stability feed for Power BI live monitoring.
# FleetPulse reads this feed as a read-only analytics projection; Xcelerator
# remains authoritative for orders, revenue, driver pay, and route assignments.
FLEETPULSE_LANE_STABILITY_ORDER_FEED_URL=
FLEETPULSE_LANE_STABILITY_ORDER_FEED_PATH=
FLEETPULSE_LANE_STABILITY_ORDER_FEED_API_KEY=
FLEETPULSE_LANE_STABILITY_ORDER_FEED_API_KEY_HEADER=X-FleetPulse-Lane-Stability-Key
FLEETPULSE_LANE_STABILITY_BASELINE_ORDER_FEED_URL=
FLEETPULSE_LANE_STABILITY_BASELINE_ORDER_FEED_PATH=
FLEETPULSE_LANE_STABILITY_BASELINE_ORDER_FEED_API_KEY=
FLEETPULSE_LANE_STABILITY_BASELINE_ORDER_FEED_API_KEY_HEADER=X-FleetPulse-Lane-Stability-Key
FLEETPULSE_LANE_STABILITY_PAYLOAD_URL=
FLEETPULSE_LANE_STABILITY_PAYLOAD_PATH=
FLEETPULSE_LANE_STABILITY_BASELINE_PAYLOAD_URL=
FLEETPULSE_LANE_STABILITY_BASELINE_PAYLOAD_PATH=
FLEETPULSE_LANE_STABILITY_EXCLUDED_SCORING_SERVICES=ATL-ShipBob
FLEETPULSE_LANE_STABILITY_EXCLUDED_SCORING_REF_PATTERNS=pay ticket,route ticket,tonu,service-only
