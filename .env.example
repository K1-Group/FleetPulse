GEOTAB_USERNAME=your_username
GEOTAB_PASSWORD=your_password
GEOTAB_DATABASE=k1logistics
GEOTAB_SERVER=my.geotab.com

# AI Provider Configuration
# Store production secret values in Azure Key Vault/App Settings, not in this file.
OPENROUTER_API_KEY=your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_SITE_URL=https://k1-fleetpulse.azurewebsites.net
OPENROUTER_APP_NAME=FleetPulse

# FleetPulse live data scope
# Count active Geotab power units, not inactive history or trailers.
FLEETPULSE_DEVICE_GROUP_IDS=GroupVehicleId
FLEETPULSE_EXCLUDED_DEVICE_GROUP_IDS=GroupTrailerId
FLEETPULSE_REQUIRE_ACTIVE_LIFECYCLE=true
FLEETPULSE_STATUS_STALE_HOURS=24
FLEETPULSE_SAFETY_DEMO_MODE=false
FLEETPULSE_MONITOR_ENABLED=false
FLEETPULSE_GEOTAB_TIMEOUT_SECONDS=10
FLEETPULSE_GEOTAB_MAX_WORKERS=4
FLEETPULSE_DATA_CONNECTOR_MAX_CONCURRENT_REQUESTS=6
FLEETPULSE_DATA_CONNECTOR_TIMEOUT_SECONDS=20
FLEETPULSE_DATA_CONNECTOR_RETRY_COUNT=1
FLEETPULSE_DATA_CONNECTOR_QUEUE_TIMEOUT_SECONDS=5
FLEETPULSE_CACHE_TTL_SECONDS=30
FLEETPULSE_CACHE_FALLBACK_SECONDS=300
FLEETPULSE_CACHE_REFRESH_WAIT_SECONDS=30
FLEETPULSE_HUBS_CONFIG_PATH=backend/configs/fleet_hubs.json
# Optional JSON override for hub metadata/radii. Use app settings or Key Vault,
# not code changes, when production hub boundaries need operational adjustment.
# FLEETPULSE_HUBS_JSON={"default_radius_miles":25,"hubs":[{"name":"Austin Hub","address":"Austin, TX","latitude":30.2672,"longitude":-97.7431,"radius_miles":25}]}

# Optional Microsoft Entra login. Azure App Service Authentication / Easy Auth
# is the identity authority. Keep AUTH_REQUIRED=false for public dashboard mode;
# set LOGIN_ENABLED=true to show the sign-in control without forcing SSO.
FLEETPULSE_ENTRA_LOGIN_ENABLED=true
FLEETPULSE_ENTRA_AUTH_REQUIRED=false
FLEETPULSE_ENTRA_SEAT_ACCESS_ENFORCED=false
FLEETPULSE_ENTRA_AUDIT_DECISIONS=true
FLEETPULSE_ENTRA_PUBLIC_TABS=dashboard,control-tower,maintenance,stability
FLEETPULSE_ENTRA_SEAT_GROUPS_JSON={"executive_command":{"groupId":"<EXECUTIVE_COMMAND_SEAT_GROUP_OBJECT_ID>"},"revenue_manager":{"groupId":"<REVENUE_MANAGER_SEAT_GROUP_OBJECT_ID>"},"operations_manager":{"groupId":"<OPERATIONS_MANAGER_SEAT_GROUP_OBJECT_ID>"},"finance_controller":{"groupId":"<FINANCE_CONTROLLER_SEAT_GROUP_OBJECT_ID>"},"fleet_compliance_manager":{"groupId":"<FLEET_COMPLIANCE_MANAGER_SEAT_GROUP_OBJECT_ID>"},"people_systems_manager":{"groupId":"<PEOPLE_SYSTEMS_MANAGER_SEAT_GROUP_OBJECT_ID>"}}

