GEOTAB_USERNAME=your_username
GEOTAB_PASSWORD=your_password
GEOTAB_DATABASE=k1logistics
GEOTAB_SERVER=my.geotab.com

# OPTIONAL: pin the OData Data Connector federation server explicitly.
# When unset, the backend auto-discovers by probing odata-connector-{1..15}
# with a real table query (validates jurisdiction). Set this once you know
# which server matches your database to skip discovery and prevent the
# "Jurisdiction Mismatch" issue from recurring.
# Example: GEOTAB_ODATA_SERVER=https://odata-connector-3.geotab.com/odata/v4/svc/
#GEOTAB_ODATA_SERVER=
