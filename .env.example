# OPTIONAL: pin the OData Data Connector access URL explicitly.
# When unset, the backend starts at Geotab's unified redirect URL:
# https://data-connector.geotab.com/odata/v4/svc/
# and falls back to odata-connector-{1..15} with a real table query.
# Set this to the Access URL shown in the MyGeotab Data Connector add-in
# if discovery ever returns Jurisdiction Mismatch.
# Current K1logistics discovery result:
GEOTAB_ODATA_SERVER=https://odata-connector-2.geotab.com/odata/v4/svc/
